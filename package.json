{
    "name": "skillfs",
    "version": "1.2.0",
    "description": "De-duplicate and centralize agent skills across directories",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "sk": "./dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.js",
        "test": "vitest run",
        "prepublishOnly": "pnpm run build && pnpm test"
    },
    "keywords": [
        "ai-agent",
        "skills",
        "deduplication",
        "symlink",
        "claude",
        "clawdbot",
        "cli",
        "agent-skills",
        "skill-management"
    ],
    "author": "Jace (Sanage)",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "https://github.com/ares0x/skillfs"
    },
    "bugs": {
        "url": "https://github.com/ares0x/skillfs/issues"
    },
    "homepage": "https://github.com/ares0x/skillfs#readme",
    "files": [
        "dist/",
        "README.md",
        "README_CN.md",
        "LICENSE"
    ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.15.0",
    "dependencies": {
        "commander": "^12.0.0",
        "chalk": "^5.3.0",
        "inquirer": "^9.2.12"
    },
    "devDependencies": {
        "typescript": "^5.3.3",
        "@types/node": "^20.11.0",
        "@types/inquirer": "^9.0.7",
        "tsx": "^4.7.1",
        "vitest": "^2.1.0"
    }
}
